{
  "lineBudgets": [
    {
      "path": "App.tsx",
      "maxLines": 430,
      "softWarnPercent": 90,
      "rationale": "Root app orchestration should not keep absorbing feature state and case-by-case UI wiring.",
      "suggestedExtractionTarget": "Move focused state or capability workflows into hooks or feature modules before adding new root behavior."
    }
  ],
  "productionRoots": [
    "App.tsx",
    "components",
    "packages"
  ],
  "productionExtensions": [
    ".js",
    ".mjs",
    ".ts",
    ".tsx"
  ],
  "ignoredDirectories": [
    "node_modules",
    "dist",
    ".vite"
  ],
  "sampleOnlyMarkers": [
    "placehold.co",
    "baidu.com",
    "random-001",
    "morndraft-2026-05-22-dev-random-001"
  ],
  "forbiddenCoreImports": [
    "react",
    "react-dom",
    "lucide-react",
    "../components/",
    "../../components/",
    "../services/",
    "../../services/"
  ],
  "forbiddenFileImports": []
}
